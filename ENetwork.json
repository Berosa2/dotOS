  {
    "id": "bes:aura",
    "content": "<body style=\"margin:0;font-family:Segoe UI,Arial;background:#0f172a;color:white;padding:20px;\"><div style=\"max-width:700px;margin:auto;\"><h1 id=\"aura\" style=\"font-size:28px;\">Aura Farming Course</h1><p style=\"opacity:0.7;\">Learn how to gain \"aura\" (charisma & coolness)</p><hr style=\"border:1px solid #1e293b;\"><h2>Module 1</h2><p>Doing positive or impressive actions increases your \"aura\". Example: helping others, achieving goals, being confident.</p><button onclick=\"aura()\" style=\"margin-top:15px;padding:10px 15px;border:none;border-radius:8px;background:#22c55e;color:white;cursor:pointer;\">Show Example</button></div><script>function sendToGame(action){window.parent.postMessage({type:'gdevelop_event',action:action},'*');}function aura(){document.getElementById('aura').textContent='😇 MAX AURA';}</script></body>"
  },

  {
    "id": "bes:docs",
    "content": "<body style=\"margin:0;font-family:Segoe UI,Arial;background:#0f172a;color:white;\"><div style=\"display:flex;height:100vh;\"><div style=\"width:240px;background:#1e293b;padding:15px;box-sizing:border-box;\"><h2>Docs</h2><button onclick=\"showPage('intro')\" style=\"width:100%;margin-bottom:8px;padding:8px;border:none;border-radius:6px;background:#334155;color:white;cursor:pointer;\">Introduction</button><button onclick=\"showPage('protocols')\" style=\"width:100%;margin-bottom:8px;padding:8px;border:none;border-radius:6px;background:#334155;color:white;cursor:pointer;\">Protocols</button><button onclick=\"showPage('apps')\" style=\"width:100%;margin-bottom:8px;padding:8px;border:none;border-radius:6px;background:#334155;color:white;cursor:pointer;\">Apps</button><hr style=\"border:1px solid #334155;\"><button onclick=\"sendToGame('NAV_HOME')\" style=\"width:100%;padding:8px;border:none;border-radius:6px;background:#3b82f6;color:white;cursor:pointer;\">Home</button></div><div id=\"content\" style=\"flex:1;padding:25px;overflow:auto;\"><h1>Welcome</h1><p style=\"opacity:0.7;\">Select a section.</p></div></div><script>function sendToGame(action){window.parent.postMessage({type:'gdevelop_event',action:action},'*');}function showPage(page){var c=document.getElementById('content');if(page==='intro'){c.innerHTML='<h1>Introduction</h1><p>ENetwork is a modular system where apps communicate using events.</p>';}if(page==='protocols'){c.innerHTML='<h1>Protocols</h1><ul><li>.enc → Commerce</li><li>.eng → Games</li><li>.enp → Prototype</li></ul>';}if(page==='apps'){c.innerHTML='<h1>Apps</h1><p>Official apps use bes: prefix. Custom apps use bess:.</p>';}}</script></body>"
  },

  {
